# ============================================================
# .env.example — copia para .env e preenche os valores reais.
# NUNCA committar o .env com valores reais!
# ============================================================

# ── Playwright / comportamento do scraper ────────────────────
HEADLESS=true          # false (ou usar --headful) para ver o browser
SLOW_MO=0              # ms entre acções do Playwright
DEFAULT_TIMEOUT=20000  # timeout padrão (ms)

# ── ExchangeRate-API (conversão de moeda, opcional) ──────────
CURRENCY_API_KEY=a_tua_chave
URL_CURRENCY_API=https://v6.exchangerate-api.com/v6/<chave>/latest/EUR
TARGET_CURRENCIES=['EUR','USD','GBP','BRL','COP','MXN','PEN','ARS','CLP']

# ── Captcha (2captcha) — necessário para contas Betano ───────────────────────
TWOCAPTCHA_API_KEY=a_tua_chave_2captcha

# ── Google Sheets (OAuth com a conta do utilizador) ──────────
# Credenciais OAuth "App de computador" do Google Cloud (não committar).
# Na 1ª execução abre o navegador para autorizar; o token fica em token_json.
# Rotação/revogação: para forçar novo login, apaga config/authorized_user.json
# (regenerado no próximo --pull-ref). Revoga o acesso em
# https://myaccount.google.com/permissions se necessário.
GOOGLE_OAUTH_CLIENT_JSON=config/oauth_client.json
GOOGLE_OAUTH_TOKEN_JSON=config/authorized_user.json
GSHEET_ID=id_da_planilha            # trecho entre /d/ e /edit no URL
GSHEET_REF_TAB=ref                  # aba lida para atualizar o config/ref.xlsx
GSHEET_UNION_TAB=union_data         # aba de destino do report/union_data.csv

# ── Passwords das contas Netrefer ────────────────────────────
# Convenção:  PASS_NETREFER_<OPERADOR>_<USERNAME>
# (@, ., espaços e outros caracteres viram _ ; tudo em maiúsculas)
# Usar aspas para proteger senhas com # ou outros caracteres especiais.
#
# Exemplos:
PASS_NETREFER_BETMGM_TIPSTERPAGEBR="senha123"
PASS_NETREFER_SNAI_SCOM1="outrasenha"

# ── Passwords das contas Income Access ───────────────────────
# Convenção:  PASS_INCOME_ACCESS_<OPERADOR>_<USERNAME>
#
# Exemplos:
PASS_INCOME_ACCESS_BETANO_TIPSTERPAGEBR="senha123"
PASS_INCOME_ACCESS_WILLIAMHILL_AFFILIABET2="outrasenha"
#
# Para gerar todas automaticamente a partir do config/logins.xlsx:
#   python scripts/seed_env_passwords.py
# e acrescenta o conteúdo de .env.passwords a este ficheiro.
